# ── Base de datos (Neon) ──────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/dbname?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://user:pass@ep-xxx-direct.neon.tech/dbname?sslmode=require

# ── Auth (Better Auth) ────────────────────────────────────────────────
BETTER_AUTH_SECRET=genera-con-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3000

# ── Email (Resend) ────────────────────────────────────────────────────
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL="Turnflow <no-reply@turnflow.co>"

# ── Push notifications (VAPID) ────────────────────────────────────────
# Generar con: node -e "const {generateVapidKeys} = require('@lynkko/push'); console.log(generateVapidKeys())"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hola@lynkko.co

# ── Pagos (Wompi) ─────────────────────────────────────────────────────
WOMPI_PUBLIC_KEY=pub_test_xxx
WOMPI_PRIVATE_KEY=prv_test_xxx
WOMPI_WEBHOOK_SECRET=
WOMPI_SANDBOX=true   # quitar en producción

# ── App ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Turnflow by Lynkko"

# ── GitHub Packages (CI/deploy) ───────────────────────────────────────
# Requerido para instalar @lynkko/* en Vercel
GITHUB_TOKEN=ghp_xxx
